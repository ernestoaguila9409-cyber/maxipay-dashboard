NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only: paste the ENTIRE Firebase service account JSON.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Resend (merchant welcome emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL="noreply@maxipaypos.com"

# Merchant web dashboard (password reset → "Continue" goes to …/login). No trailing slash.
# Must match a domain in Firebase → Authentication → Settings → Authorized domains.
MERCHANT_WEB_APP_URL=https://dashboard.maxipaypos.com
# Alternative name (e.g. if you only configure NEXT_PUBLIC_* on Vercel):
# NEXT_PUBLIC_MERCHANT_WEB_APP_URL=https://dashboard.maxipaypos.com
