# Copy to secrets.properties (gitignored). No quotes around values.
# Portal: iPOSpays → S.T.E.A.M → your TPN → Integrations → SPIn (Cloud) → copy Register ID + Auth Key.
# Docs: https://docs.ipospays.com/spin-specification (REST index links to Theneo).
SPIN_TPN=
SPIN_REGISTER_ID=
SPIN_AUTH_KEY=
# Production SPIn base (override for UAT if your ISO provides a different host)
SPIN_BASE_URL=https://spinpos.net/v2
