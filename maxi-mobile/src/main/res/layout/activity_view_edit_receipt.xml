<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Receipt Settings"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingBottom="4dp"/>

        <!-- P8 info banner -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dejavoo P8 — fixed 24 characters per line. Font size is not adjustable on this device."
            android:textSize="11sp"
            android:textColor="#666666"
            android:background="#E8EAF6"
            android:padding="10dp"
            android:layout_marginBottom="16dp"/>

        <!-- Business Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Business Name"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#555555"/>

        <EditText
            android:id="@+id/etBusinessName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:maxLength="24"
            android:hint="Enter business name"
            android:textSize="14sp"
            android:padding="10dp"
            android:background="@android:color/white"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvBizNameLineHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginBottom="12dp"/>

        <!-- Address -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Address"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#555555"/>

        <EditText
            android:id="@+id/etAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textMultiLine"
            android:hint="Enter address (one line per row)"
            android:textSize="14sp"
            android:padding="10dp"
            android:minLines="3"
            android:background="@android:color/white"
            android:gravity="top"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvAddressLineHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="11sp"
            android:textColor="#888888"
            android:layout_marginBottom="16dp"/>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Display Options"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:paddingBottom="12dp"/>

        <!-- Show Server Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show Server Name"
                android:textSize="14sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchShowServer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Show Date/Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show Date/Time"
                android:textSize="14sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchShowDateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Show Email -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="12dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show Email"
                android:textSize="14sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchShowEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"/>

        <!-- Bold Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bold"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:paddingBottom="12dp"/>

        <!-- Bold: Business Name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Business Name"
                android:textSize="13sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBoldBizName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Bold: Address -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Address"
                android:textSize="13sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBoldAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Bold: Order Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Order Info"
                android:textSize="13sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBoldOrderInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Bold: Items -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Items"
                android:textSize="13sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBoldItems"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Bold: Totals -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Totals"
                android:textSize="13sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBoldTotals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Bold: Grand Total -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Grand Total"
                android:textSize="13sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBoldGrandTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Bold: Footer -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Footer"
                android:textSize="13sp"/>
            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBoldFooter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#CCCCCC"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"/>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Settings"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:backgroundTint="#6A4FB3"/>

        <!-- View Receipt Button -->
        <Button
            android:id="@+id/btnViewReceipt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="View Receipt"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:backgroundTint="#1976D2"/>

        <!-- Print Test Receipt Button -->
        <Button
            android:id="@+id/btnTestReceipt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Print Test Receipt"
            android:textAllCaps="false"
            android:textSize="15sp"
            android:backgroundTint="#4CAF50"/>

        <!-- Reset Button -->
        <Button
            android:id="@+id/btnResetDefaults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Reset to Defaults"
            android:textAllCaps="false"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:textColor="#6A4FB3"
            app:strokeColor="#6A4FB3"/>

    </LinearLayout>
</ScrollView>
