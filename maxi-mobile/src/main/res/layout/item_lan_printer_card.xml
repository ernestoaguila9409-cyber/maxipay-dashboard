<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtPrinterCardTypeLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#1C1B1F"
            android:textSize="12sp"
            android:textStyle="bold"
            tools:text="@string/kitchen_printer" />

        <TextView
            android:id="@+id/txtPrinterCardStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:text="@string/printer_status_checking"
            android:textColor="@color/printer_status_checking"
            android:textSize="13sp"
            android:textStyle="bold"
            tools:text="Online" />

        <TextView
            android:id="@+id/txtPrinterCardName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:textColor="#1C1B1F"
            android:textSize="18sp"
            android:textStyle="bold"
            tools:text="Bar" />

        <TextView
            android:id="@+id/txtPrinterCardIp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:textColor="#49454F"
            android:textSize="15sp"
            tools:text="10.0.0.221" />

        <TextView
            android:id="@+id/txtPrinterCardInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:textColor="#757575"
            android:textSize="14sp"
            tools:text="Star Micronics SP700" />

        <TextView
            android:id="@+id/txtPrinterCardLabels"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:textColor="#6A4FB3"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="Labels: Drinks, Grill"
            tools:visibility="visible" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnPrinterCardTest"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/printer_test_print" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
