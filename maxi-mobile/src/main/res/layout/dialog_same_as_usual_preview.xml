<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/txtRepeatDialogTitle"
        android:text="Same as usual?"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2E2548"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <TextView
        android:id="@+id/txtRepeatDialogSubtitle"
        android:text="Based on recent visits"
        android:textSize="12sp"
        android:textColor="#5D4E7B"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="2dp"/>

    <LinearLayout
        android:id="@+id/containerRepeatDialogItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="12dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E0E0E0"
        android:layout_marginTop="12dp"/>

    <TextView
        android:id="@+id/txtRepeatDialogTotal"
        android:text=""
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#2E2548"
        android:gravity="end"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:paddingTop="14dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRepeatDialogClose"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="Close"
            android:textSize="13sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRepeatDialogApply"
            android:text="Repeat order"
            android:textSize="13sp"
            android:backgroundTint="#6A4FB3"
            android:textColor="#FFFFFF"
            android:layout_marginStart="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
</LinearLayout>
