<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/pendingOnlineOrderSign"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginTop="10dp"
    android:layout_marginEnd="12dp"
    android:visibility="gone"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="14dp"
    app:cardElevation="6dp"
    app:strokeColor="@color/brand_primary"
    app:strokeWidth="2dp"
    tools:visibility="visible">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="14dp"
        android:paddingEnd="18dp"
        android:paddingBottom="14dp">

        <TextView
            android:id="@+id/txtPendingOnlineSignTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pending_online_sign_title"
            android:textColor="@color/brand_primary"
            android:textSize="17sp"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:id="@+id/txtPendingOnlineSignOrderLine"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textColor="@color/pos_primary_text"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            tools:text="Order #1042 · 3 items" />

        <TextView
            android:id="@+id/txtPendingOnlineSignCustomer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/pos_primary_text"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            tools:text="Jordan Lee" />

        <TextView
            android:id="@+id/txtPendingOnlineSignPayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/pos_secondary_text"
            android:textSize="14sp"
            tools:text="Payment: pay at pickup" />

        <TextView
            android:id="@+id/txtPendingOnlineSignMore"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:visibility="gone"
            android:textColor="@color/pos_secondary_text"
            android:textSize="14sp"
            tools:text="+ 2 more orders awaiting"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/txtPendingOnlineSignHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pending_online_sign_tap_hint"
            android:textColor="@color/pos_secondary_text"
            android:textSize="13sp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
