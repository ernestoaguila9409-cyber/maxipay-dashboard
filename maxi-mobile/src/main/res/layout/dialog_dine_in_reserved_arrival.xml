<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="16dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/txtReservedArrivalDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:lineSpacingExtra="4dp"
        android:textColor="#333333"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/btnSeatGuest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="@string/dine_in_reserved_seat_guest"
            android:textAllCaps="false"
            android:textColor="#2E7D32"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnCancelReservation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="@string/dine_in_reserved_cancel_reservation"
            android:textAllCaps="false"
            android:textColor="#C62828"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/btnCloseReservedDialog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackground"
            android:gravity="center"
            android:paddingVertical="12dp"
            android:text="@string/dine_in_reserved_close"
            android:textAllCaps="false"
            android:textColor="#5D4037"
            android:textSize="15sp" />
    </LinearLayout>
</LinearLayout>
