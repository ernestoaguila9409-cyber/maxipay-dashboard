<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/cartLineName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/order_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="Classic Burger" />

        <TextView
            android:id="@+id/cartLineUnitPrice"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textColor="@color/order_text_secondary"
            android:textSize="13sp"
            tools:text="$12.99 each" />

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/cartLineDecrease"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_order_add_button"
            android:contentDescription="@string/order_decrease_quantity"
            android:padding="8dp"
            android:src="@drawable/ic_minus"
            app:tint="@color/order_text_primary" />

        <TextView
            android:id="@+id/cartLineQuantity"
            android:layout_width="32dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/order_text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            tools:text="2" />

        <ImageButton
            android:id="@+id/cartLineIncrease"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_order_add_button"
            android:contentDescription="@string/order_increase_quantity"
            android:padding="8dp"
            android:src="@drawable/ic_plus"
            app:tint="@color/order_text_primary" />

    </LinearLayout>

    <TextView
        android:id="@+id/cartLineTotal"
        android:layout_width="72dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/order_text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        tools:text="$25.98" />

</LinearLayout>
