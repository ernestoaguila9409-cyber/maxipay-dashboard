<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bar Tab Configuration"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configure pre-authorization settings for bar tabs."
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:paddingBottom="32dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pre-Auth Hold Amount ($)"
        android:textSize="14sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <EditText
        android:id="@+id/edtPreAuthAmount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        android:padding="14dp"
        android:textSize="16sp"
        android:inputType="numberDecimal"
        android:hint="50"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="This amount is held on the customer's card when a new bar tab is opened."
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:paddingTop="8dp"
        android:paddingBottom="32dp"/>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveBarTabConfig"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save"
        android:textSize="16sp"
        android:backgroundTint="#6A4FB3"/>

</LinearLayout>
