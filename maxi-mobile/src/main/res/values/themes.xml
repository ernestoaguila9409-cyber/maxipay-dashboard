<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Opaque system bars so the 3-button nav row stays visible (transparent bars + white UI hid icons). -->
    <style name="Theme.MaxiMobile" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/white</item>
        <item name="android:navigationBarColor">#E8EAED</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
