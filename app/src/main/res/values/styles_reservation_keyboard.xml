<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ReservationKeyboardKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">2dp</item>
        <item name="android:background">@drawable/bg_pos_key_default</item>
        <item name="android:textColor">@color/pos_key_text_primary</item>
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingLeft">2dp</item>
        <item name="android:paddingRight">2dp</item>
        <!-- AppCompatButton: avoid Material-inflated tint hiding the white key drawable -->
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Compact keys for the floating numeric time dialog (fits under ~380dp height). -->
    <style name="ReservationNumericTimeKey">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">@dimen/reservation_numeric_time_key_height</item>
        <item name="android:layout_weight">1</item>
        <item name="android:layout_margin">@dimen/reservation_numeric_time_key_margin</item>
        <item name="android:background">@drawable/bg_pos_key_default</item>
        <item name="android:textColor">@color/pos_key_text_primary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:paddingLeft">2dp</item>
        <item name="android:paddingRight">2dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>
</resources>
