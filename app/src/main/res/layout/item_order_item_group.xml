<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <!-- Collapsed / header row: tap toggles expand -->
    <LinearLayout
        android:id="@+id/groupHeaderRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtGroupChevron"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶"
            android:textSize="12sp"
            android:textColor="#666666"
            android:paddingEnd="8dp" />

        <TextView
            android:id="@+id/txtGroupNameQty"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="#222222" />

        <androidx.compose.ui.platform.ComposeView
            android:id="@+id/kdsStatusComposeGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtGroupLineTotal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textStyle="bold"
        android:textSize="13sp"
        android:textColor="#1B5E20"
        android:layout_marginTop="6dp"
        android:layout_marginStart="20dp" />

    <TextView
        android:id="@+id/txtGroupRefundedBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="REFUNDED"
        android:textSize="11sp"
        android:textStyle="bold"
        android:textColor="#C62828"
        android:layout_marginTop="4dp"
        android:layout_marginStart="20dp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/groupChildContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:visibility="gone" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginTop="10dp" />

</LinearLayout>
