<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#F5F5F5">

    <TextView
        android:id="@+id/txtActivationInstructions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/device_activation_instructions"
        android:textSize="15sp"
        android:textColor="@android:color/darker_gray"
        android:paddingBottom="16dp" />

    <EditText
        android:id="@+id/editActivationCode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="@string/device_activation_hint"
        android:inputType="number"
        android:maxLength="6"
        android:padding="16dp"
        android:background="@android:color/white"
        android:textSize="22sp"
        android:letterSpacing="0.15" />

    <Button
        android:id="@+id/btnSubmitActivation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/device_activation_submit"
        android:textAllCaps="false" />

</LinearLayout>
