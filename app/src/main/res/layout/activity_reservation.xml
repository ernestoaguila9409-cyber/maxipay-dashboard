<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F0F5"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:background="@color/white"
        android:elevation="3dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/reservation_back_cd"
            android:padding="12dp"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/reservation_screen_title"
            android:textColor="@color/pos_primary_text"
            android:textSize="22sp"
            android:textStyle="bold" />
    </LinearLayout>

    <RadioGroup
        android:id="@+id/groupReservationFilter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/headerLayout"
        android:background="@color/white"
        android:elevation="2dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingTop="10dp"
        android:paddingEnd="12dp"
        android:paddingBottom="10dp">

        <RadioButton
            android:id="@+id/radioReservationsActive"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_reservation_filter_segment"
            android:button="@null"
            android:checked="true"
            android:gravity="center"
            android:minHeight="44dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/reservation_filter_active"
            android:textColor="@color/selector_reservation_filter_text"
            android:textSize="15sp" />

        <RadioButton
            android:id="@+id/radioReservationsClosed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_reservation_filter_segment"
            android:button="@null"
            android:gravity="center"
            android:minHeight="44dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/reservation_filter_closed"
            android:textColor="@color/selector_reservation_filter_text"
            android:textSize="15sp" />
    </RadioGroup>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerReservations"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/groupReservationFilter"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingTop="16dp"
        android:paddingEnd="12dp"
        android:paddingBottom="96dp"
        android:scrollbars="vertical" />

    <LinearLayout
        android:id="@+id/reservationEmptyState"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/groupReservationFilter"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingStart="40dp"
        android:paddingEnd="40dp"
        android:visibility="gone">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:alpha="0.35"
            android:contentDescription="@null"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_calendar"
            app:tint="@color/brand_primary" />

        <TextView
            android:id="@+id/txtReservationEmptyTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:text="@string/reservation_list_empty_title"
            android:textColor="@color/pos_primary_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtReservationEmptySubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:lineSpacingExtra="2dp"
            android:text="@string/reservation_list_empty_subtitle"
            android:textColor="@color/pos_secondary_text"
            android:textSize="15sp" />
    </LinearLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddReservation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="24dp"
        android:contentDescription="@string/reservation_fab_add_cd"
        android:src="@drawable/ic_plus"
        app:backgroundTint="@color/brand_primary"
        app:tint="@android:color/white" />
</RelativeLayout>
