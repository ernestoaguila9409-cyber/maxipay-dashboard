<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#EEEEEE">

    <!-- LEFT: Settings Panel -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#F5F5F5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Receipt Settings"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingBottom="16dp"/>

            <!-- Business Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Business Name"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#555555"/>

            <EditText
                android:id="@+id/etBusinessName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:hint="Enter business name"
                android:textSize="14sp"
                android:padding="10dp"
                android:background="@android:color/white"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="12dp"/>

            <!-- Address -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#555555"/>

            <EditText
                android:id="@+id/etAddress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:hint="Enter address (one line per row)"
                android:textSize="14sp"
                android:padding="10dp"
                android:minLines="3"
                android:background="@android:color/white"
                android:gravity="top"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Display Options"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:paddingBottom="12dp"/>

            <!-- Show Server Name toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Show Server Name"
                    android:textSize="14sp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchShowServer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Show Date/Time toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Show Date/Time"
                    android:textSize="14sp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchShowDateTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>

            <!-- ═══ Bold Section ═══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bold"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:paddingBottom="12dp"/>

            <!-- Bold: Business Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Business Name"
                    android:textSize="13sp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchBoldBizName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Bold: Address -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Address"
                    android:textSize="13sp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchBoldAddress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Bold: Order Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Order Info"
                    android:textSize="13sp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchBoldOrderInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Bold: Items -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Items"
                    android:textSize="13sp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchBoldItems"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Bold: Totals -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Totals"
                    android:textSize="13sp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchBoldTotals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Bold: Grand Total -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Grand Total"
                    android:textSize="13sp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchBoldGrandTotal"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Bold: Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Footer"
                    android:textSize="13sp"/>

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchBoldFooter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>

            <!-- ═══ Font Size Section ═══ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Font Size"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:paddingBottom="12dp"/>

            <!-- Font: Business Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Biz Name"
                    android:textSize="13sp"/>

                <SeekBar
                    android:id="@+id/seekFontBizName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="2"
                    android:progress="2"/>

                <TextView
                    android:id="@+id/tvFontBizNameVal"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="X-Large"
                    android:textSize="11sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Font: Address -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Address"
                    android:textSize="13sp"/>

                <SeekBar
                    android:id="@+id/seekFontAddress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="2"
                    android:progress="2"/>

                <TextView
                    android:id="@+id/tvFontAddressVal"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="X-Large"
                    android:textSize="11sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Font: Order Info -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Order Info"
                    android:textSize="13sp"/>

                <SeekBar
                    android:id="@+id/seekFontOrderInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="2"
                    android:progress="2"/>

                <TextView
                    android:id="@+id/tvFontOrderInfoVal"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="X-Large"
                    android:textSize="11sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Font: Items -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Items"
                    android:textSize="13sp"/>

                <SeekBar
                    android:id="@+id/seekFontItems"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="2"
                    android:progress="0"/>

                <TextView
                    android:id="@+id/tvFontItemsVal"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="Normal"
                    android:textSize="11sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Font: Totals -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Totals"
                    android:textSize="13sp"/>

                <SeekBar
                    android:id="@+id/seekFontTotals"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="2"
                    android:progress="0"/>

                <TextView
                    android:id="@+id/tvFontTotalsVal"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="Normal"
                    android:textSize="11sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Font: Grand Total -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Grand Total"
                    android:textSize="13sp"/>

                <SeekBar
                    android:id="@+id/seekFontGrandTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="2"
                    android:progress="1"/>

                <TextView
                    android:id="@+id/tvFontGrandTotalVal"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="Large"
                    android:textSize="11sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Font: Footer -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <TextView
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:text="Footer"
                    android:textSize="13sp"/>

                <SeekBar
                    android:id="@+id/seekFontFooter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="2"
                    android:progress="0"/>

                <TextView
                    android:id="@+id/tvFontFooterVal"
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:text="Normal"
                    android:textSize="11sp"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"/>

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Settings"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:backgroundTint="#6A4FB3"/>

            <!-- Print Test Receipt Button -->
            <Button
                android:id="@+id/btnTestReceipt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Print Test Receipt"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:backgroundTint="#4CAF50"/>

            <!-- Reset Button -->
            <Button
                android:id="@+id/btnResetDefaults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Reset to Defaults"
                android:textAllCaps="false"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#6A4FB3"
                app:strokeColor="#6A4FB3"/>

        </LinearLayout>
    </ScrollView>

    <!-- RIGHT: Receipt Preview -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="#DDDDDD"
        android:padding="16dp">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center_horizontal"
            android:background="@android:color/white"
            android:elevation="6dp"
            android:clipToPadding="false">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="24dp"
                android:paddingBottom="32dp">

                <!-- Business Name -->
                <TextView
                    android:id="@+id/tvBusinessName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="My Restaurant"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:gravity="center"/>

                <!-- Address -->
                <TextView
                    android:id="@+id/tvAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingTop="4dp"/>

                <!-- RECEIPT title -->
                <TextView
                    android:id="@+id/tvReceiptTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="RECEIPT"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:paddingBottom="4dp"/>

                <!-- Order Info -->
                <TextView
                    android:id="@+id/tvOrderInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingBottom="4dp"/>

                <!-- Items separator -->
                <TextView
                    android:id="@+id/tvSep1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

                <!-- Items -->
                <TextView
                    android:id="@+id/tvItems"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="12sp"/>

                <!-- Totals separator -->
                <TextView
                    android:id="@+id/tvSep2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

                <!-- Totals -->
                <TextView
                    android:id="@+id/tvTotals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="12sp"/>

                <!-- Grand total separator -->
                <TextView
                    android:id="@+id/tvSep3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:paddingTop="2dp"
                    android:paddingBottom="4dp"/>

                <!-- Grand total -->
                <TextView
                    android:id="@+id/tvGrandTotal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textSize="14sp"
                    android:gravity="start"/>

                <!-- Payment Info -->
                <TextView
                    android:id="@+id/tvPaymentInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:paddingTop="12dp"/>

                <!-- Footer -->
                <TextView
                    android:id="@+id/tvFooter"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:paddingTop="16dp"/>

            </LinearLayout>
        </ScrollView>
    </FrameLayout>

</LinearLayout>
