<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tips"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configure tip options for your customers."
        android:textSize="16sp"
        android:textColor="@android:color/darker_gray"
        android:paddingBottom="16dp"/>

    <!-- Where tips are collected (shown first) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="WHERE TO COLLECT TIPS"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@android:color/darker_gray"
        android:paddingBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Choose before adjusting presets and other options below."
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:paddingBottom="12dp"/>

    <LinearLayout
        android:id="@+id/tipPresentationContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="16dp"
        android:layout_marginBottom="8dp">

        <RadioGroup
            android:id="@+id/rgTipPresentation"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbTipCustomerScreen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tips on customer-facing screen"
                android:textSize="15sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

            <RadioButton
                android:id="@+id/rbTipReceipt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tips on the receipt"
                android:textSize="15sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

        </RadioGroup>
    </LinearLayout>

    <!-- Enable Tips -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@android:color/white"
        android:padding="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ENABLE TIPS"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchTipsEnabled"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Preset Percentages Section -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PRESET TIP PERCENTAGES"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@android:color/darker_gray"
        android:paddingTop="24dp"
        android:paddingBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Leave blank to hide option from customers."
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:paddingBottom="12dp"/>

    <LinearLayout
        android:id="@+id/presetsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@android:color/white"
        android:padding="12dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opt 1"
                android:textSize="11sp"
                android:textColor="@android:color/darker_gray"/>

            <EditText
                android:id="@+id/etPreset1"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:hint="—"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="%"
                android:textSize="12sp"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="44dp"
            android:background="#E0E0E0"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opt 2"
                android:textSize="11sp"
                android:textColor="@android:color/darker_gray"/>

            <EditText
                android:id="@+id/etPreset2"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:hint="—"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="%"
                android:textSize="12sp"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="44dp"
            android:background="#E0E0E0"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opt 3"
                android:textSize="11sp"
                android:textColor="@android:color/darker_gray"/>

            <EditText
                android:id="@+id/etPreset3"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:hint="—"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="%"
                android:textSize="12sp"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="44dp"
            android:background="#E0E0E0"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opt 4"
                android:textSize="11sp"
                android:textColor="@android:color/darker_gray"/>

            <EditText
                android:id="@+id/etPreset4"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:hint="—"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="%"
                android:textSize="12sp"/>
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="44dp"
            android:background="#E0E0E0"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Opt 5"
                android:textSize="11sp"
                android:textColor="@android:color/darker_gray"/>

            <EditText
                android:id="@+id/etPreset5"
                android:layout_width="52dp"
                android:layout_height="wrap_content"
                android:inputType="number"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:hint="—"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="%"
                android:textSize="12sp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Tip Calculation Base -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TIP CALCULATION BASE"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@android:color/darker_gray"
        android:paddingTop="24dp"
        android:paddingBottom="12dp"/>

    <LinearLayout
        android:id="@+id/calculationBaseContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="16dp">

        <RadioGroup
            android:id="@+id/rgCalculationBase"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/rbSubtotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Subtotal (before tax)"
                android:textSize="15sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

            <RadioButton
                android:id="@+id/rbTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Total (including tax)"
                android:textSize="15sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"/>

        </RadioGroup>
    </LinearLayout>

    <!-- Custom Tip -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@android:color/white"
        android:padding="16dp"
        android:layout_marginTop="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ALLOW CUSTOM TIP AMOUNT"
            android:textSize="16sp"
            android:textStyle="bold"/>

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/switchCustomTip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

</LinearLayout>
</ScrollView>
