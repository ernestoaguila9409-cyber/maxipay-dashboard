<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="24dp">

    <TextView
        android:id="@+id/txtPersonStep"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Split by Guest"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp"/>

    <TextView
        android:id="@+id/txtRemaining"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Drag items between guest columns to reassign"
        android:textSize="13sp"
        android:textColor="#777777"
        android:layout_marginBottom="12dp"/>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="horizontal"
        android:fadeScrollbars="false"
        android:clipToPadding="false"
        android:paddingEnd="8dp">

        <LinearLayout
            android:id="@+id/itemsContainer"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:gravity="top"
            android:paddingBottom="4dp"/>
    </HorizontalScrollView>

    <Button
        android:id="@+id/btnDonePerson"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Done with Splitting"
        android:layout_marginTop="16dp"/>

    <Button
        android:id="@+id/btnSplitByItemsCancel"
        style="?attr/materialButtonOutlinedStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Cancel"
        android:layout_marginTop="8dp"/>

</LinearLayout>
