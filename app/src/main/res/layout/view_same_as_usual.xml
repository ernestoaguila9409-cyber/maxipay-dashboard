<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/repeatSuggestionCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginTop="8dp"
    android:padding="12dp"
    android:background="@drawable/bg_repeat_suggestion_card"
    android:visibility="gone">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/txtRepeatStar"
            android:text="★"
            android:textSize="15sp"
            android:textColor="#F5B700"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="6dp"/>

        <TextView
            android:id="@+id/txtRepeatTitle"
            android:text="Same as usual?"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#2E2548"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"/>
    </LinearLayout>

    <TextView
        android:id="@+id/txtRepeatPatternSummary"
        android:text=""
        android:textSize="13sp"
        android:textColor="#5D4E7B"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="4dp"/>

    <TextView
        android:id="@+id/txtRepeatTotal"
        android:text=""
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#2E2548"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="2dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end|center_vertical"
        android:paddingTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRepeatView"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="View"
            android:textSize="12sp"
            android:minHeight="36dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="14dp"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRepeatEdit"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:text="Edit"
            android:textSize="12sp"
            android:minHeight="36dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="14dp"
            android:layout_marginStart="8dp"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnRepeatApply"
            android:text="Repeat"
            android:textSize="12sp"
            android:minHeight="36dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:paddingHorizontal="18dp"
            android:backgroundTint="#6A4FB3"
            android:textColor="#FFFFFF"
            android:layout_marginStart="8dp"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical"/>
    </LinearLayout>
</LinearLayout>
