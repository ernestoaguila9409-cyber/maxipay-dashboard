<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Add discount"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Choose type, name, value, and scope."
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:paddingBottom="24dp" />

        <!-- Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Name"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <EditText
            android:id="@+id/edtDiscountName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="text"
            android:hint="e.g. Happy Hour, Employee Discount"
            android:background="@android:color/white"
            android:padding="16dp" />

        <!-- Type: Fixed or Percentage -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Type"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <RadioGroup
            android:id="@+id/radioDiscountType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/white"
            android:padding="16dp">

            <RadioButton
                android:id="@+id/radioDiscountPercentage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Percentage"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radioDiscountFixed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Fixed" />
        </RadioGroup>

        <!-- Value -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Value"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <EditText
            android:id="@+id/edtDiscountValue"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:hint="e.g. 10 (percentage) or 5.00 (fixed)"
            android:background="@android:color/white"
            android:padding="16dp" />

        <!-- Applies To: Order or Item -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Applies To"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingTop="20dp"
            android:paddingBottom="8dp" />

        <RadioGroup
            android:id="@+id/radioDiscountApplyTo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/white"
            android:padding="16dp">

            <RadioButton
                android:id="@+id/radioApplyOrder"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Order"
                android:checked="true" />

            <RadioButton
                android:id="@+id/radioApplyItem"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Item" />
        </RadioGroup>

        <!-- Active toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@android:color/white"
            android:padding="16dp"
            android:layout_marginTop="20dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Active"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchDiscountActive"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="true" />

        </LinearLayout>

        <Button
            android:id="@+id/btnSaveDiscount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save"
            android:layout_marginTop="32dp" />

        <Button
            android:id="@+id/btnDeleteDiscount"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Remove"
            android:textColor="#B00020"
            android:layout_marginTop="12dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
