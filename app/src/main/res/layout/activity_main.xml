<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#F5F5F5">

    <!-- ==================== LEFT PANEL ==================== -->
    <LinearLayout
        android:layout_width="250dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/bg_left_panel"
        android:padding="16dp">

        <!-- Logged-in user -->
        <TextView
            android:id="@+id/txtLoggedUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logged in as:"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtEmployeeRole"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="EMPLOYEE"
            android:textColor="#B0A3D4"
            android:textSize="12sp"
            android:textAllCaps="true"
            android:letterSpacing="0.1" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:background="#44FFFFFF" />

        <!-- Sales section -->
        <LinearLayout
            android:id="@+id/todaySalesArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:padding="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="CURRENT SALES"
                android:textColor="#B0A3D4"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/txtTodayTotal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="$0.00"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtTodayCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0 transactions"
                android:textColor="#B0A3D4"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Spacer pushes logout to bottom -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Logout button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="8dp"
            android:text="Log Out"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textAllCaps="false"
            app:icon="@android:drawable/ic_lock_power_off"
            app:iconTint="@android:color/white"
            app:iconGravity="textStart"
            app:iconPadding="8dp"
            app:backgroundTint="#C62828"
            app:cornerRadius="12dp"
            app:rippleColor="#99FFFFFF" />

    </LinearLayout>

    <!-- Vertical divider -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#DDDDDD" />

    <!-- ==================== RIGHT PANEL ==================== -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <include layout="@layout/view_pending_online_order_sign" />

        <!-- Dashboard pager fills available space -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/dashboardPager"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Page indicator dots -->
        <LinearLayout
            android:id="@+id/pageIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:background="#F5F5F5" />

    </LinearLayout>

</LinearLayout>
