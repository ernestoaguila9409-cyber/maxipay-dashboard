<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- TOP TOOLBAR -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#FFFFFF"
        android:title="Restaurant POS"
        android:titleTextColor="@android:color/black"
        app:menu="@menu/main_menu" />

    <!-- CENTER CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:layout_marginTop="70dp">

        <TextView
            android:id="@+id/txtLoggedUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logged in as:"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btnTakePayment"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:text="TAKE PAYMENT"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnTransactions"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:text="TRANSACTIONS"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btnSettle"
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:text="SETTLE BATCH"
            android:layout_marginBottom="30dp"/>

        <TextView
            android:id="@+id/txtTodayTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Today: $0.00"
            android:textSize="16sp"
            android:layout_marginTop="20dp"/>

        <TextView
            android:id="@+id/txtTodayCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Transactions: 0"
            android:textSize="16sp"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnEmployees"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EMPLOYEES"
            android:layout_marginTop="20dp"
            android:backgroundTint="#6A4FB3"
            android:textColor="@android:color/white"/>

    </LinearLayout>

    <!-- LOCK BUTTON BOTTOM RIGHT -->
    <ImageButton
        android:id="@+id/btnLogout"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:background="@drawable/rounded_logout_button"
        android:src="@android:drawable/ic_lock_power_off"
        android:contentDescription="Logout"
        app:tint="@android:color/white"
        android:padding="12dp"/>
    <ImageButton
        android:id="@+id/btnHamburger"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_hamburger"
        android:contentDescription="Menu"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"/>

    <ImageButton
        android:id="@+id/btnMenuTop"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"
        android:background="@android:color/transparent"
        android:src="@drawable/ic_menu"
        android:contentDescription="Menu"
        android:padding="4dp"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"/>

    <ImageButton
        android:id="@+id/btnModifiers"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="88dp"
        android:background="@android:color/transparent"
        android:src="@drawable/rounded_assignment_24"
        android:contentDescription="Modifiers"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:clickable="true"
        android:focusable="true"/>


</FrameLayout>