<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <!-- TOP TOOLBAR -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#FFFFFF"
        android:title="Restaurant POS"
        android:titleTextColor="@android:color/black" />

    <!-- CENTER CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:layout_marginTop="70dp">

        <TextView
            android:id="@+id/txtLoggedUser"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logged in as:"
            android:layout_marginBottom="8dp"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:clipChildren="false"
            android:clipToPadding="false">

            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/homeGrid"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipChildren="false"
                android:clipToPadding="false"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintDimensionRatio="3:4"
                app:columnCount="3"
                app:rowCount="4"
                app:useDefaultMargins="false"
                app:alignmentMode="alignBounds">

                <!-- Row 0: DINE IN, TO-GO, BAR -->
                <LinearLayout
                    android:id="@+id/btnDineIn"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_margin="8dp"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_button_dine_in"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:padding="16dp"
                    android:minHeight="0dp"
                    app:layout_columnWeight="1"
                    app:layout_rowWeight="1"
                    app:layout_row="0"
                    app:layout_column="0"
                    app:layout_gravity="fill">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_dine_in"
                        android:contentDescription="Dine In"
                        app:tint="@android:color/white"/>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="8dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DINE IN"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="2"
                        android:gravity="center"/>
                </LinearLayout>

            <LinearLayout
                android:id="@+id/btnToGo"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_button_to_go"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="16dp"
                android:minHeight="0dp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1"
                app:layout_row="0"
                app:layout_column="1"
                app:layout_gravity="fill">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_to_go"
                    android:contentDescription="To Go"
                    app:tint="@android:color/white"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TO-GO"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnBar"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_button_bar"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="16dp"
                android:minHeight="0dp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1"
                app:layout_row="0"
                app:layout_column="2"
                app:layout_gravity="fill">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_bar"
                    android:contentDescription="Bar"
                    app:tint="@android:color/white"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BAR"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Row 1: TRANSACTIONS, SETTLE BATCH, EMPLOYEES -->
            <LinearLayout
                android:id="@+id/btnTransactions"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_order_type_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="16dp"
                android:minHeight="0dp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1"
                app:layout_row="1"
                app:layout_column="0"
                app:layout_gravity="fill">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_transactions"
                    android:contentDescription="Transactions"
                    app:tint="@android:color/white"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TRANSACTIONS"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnSettle"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_order_type_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="16dp"
                android:minHeight="0dp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1"
                app:layout_row="1"
                app:layout_column="1"
                app:layout_gravity="fill">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_settle_batch"
                    android:contentDescription="Settle Batch"
                    app:tint="@android:color/white"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SETTLE BATCH"
                    android:textColor="@android:color/white"
                    android:textSize="10sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="1"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnEmployees"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_order_type_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="16dp"
                android:minHeight="0dp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1"
                app:layout_row="1"
                app:layout_column="2"
                app:layout_gravity="fill">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_employees"
                    android:contentDescription="Employees"
                    app:tint="@android:color/white"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EMPLOYEES"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Row 2: CUSTOMERS -->
            <LinearLayout
                android:id="@+id/btnCustomers"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_order_type_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="16dp"
                android:minHeight="0dp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1"
                app:layout_row="2"
                app:layout_column="0"
                app:layout_gravity="fill">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_customers"
                    android:contentDescription="Customers"
                    app:tint="@android:color/white"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CUSTOMERS"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnOrders"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_order_type_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="16dp"
                android:minHeight="0dp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1"
                app:layout_row="2"
                app:layout_column="1"
                app:layout_gravity="fill">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_orders"
                    android:contentDescription="Orders"
                    app:tint="@android:color/white"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ORDERS"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Row 2 Col 2: SETUP -->
            <LinearLayout
                android:id="@+id/btnSetup"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_order_type_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="16dp"
                android:minHeight="0dp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1"
                app:layout_row="2"
                app:layout_column="2"
                app:layout_gravity="fill">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_settings"
                    android:contentDescription="Setup"
                    app:tint="@android:color/white"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SETUP"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:gravity="center"/>
            </LinearLayout>

            <!-- Row 3: MODIFIERS, INVENTORY -->
            <LinearLayout
                android:id="@+id/btnModifiers"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_order_type_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="16dp"
                android:minHeight="0dp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1"
                app:layout_row="3"
                app:layout_column="0"
                app:layout_gravity="fill">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_modifiers"
                    android:contentDescription="Modifiers"
                    app:tint="@android:color/white"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODIFIERS"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:gravity="center"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnInventory"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_margin="8dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_order_type_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                android:padding="16dp"
                android:minHeight="0dp"
                app:layout_columnWeight="1"
                app:layout_rowWeight="1"
                app:layout_row="3"
                app:layout_column="1"
                app:layout_gravity="fill">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_inventory"
                    android:contentDescription="Inventory"
                    app:tint="@android:color/white"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="INVENTORY"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-medium"
                    android:maxLines="2"
                    android:gravity="center"/>
            </LinearLayout>

        </androidx.gridlayout.widget.GridLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <LinearLayout
            android:id="@+id/todaySalesArea"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:padding="12dp">

            <TextView
                android:id="@+id/txtTodayTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Sales: $0.00"
                android:textSize="16sp"/>

            <TextView
                android:id="@+id/txtTodayCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transactions: 0"
                android:textSize="16sp"
                android:layout_marginTop="8dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- LOCK BUTTON BOTTOM RIGHT -->
    <ImageButton
        android:id="@+id/btnLogout"
        android:layout_width="55dp"
        android:layout_height="55dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:background="@drawable/rounded_logout_button"
        android:src="@android:drawable/ic_lock_power_off"
        android:contentDescription="Logout"
        app:tint="@android:color/white"
        android:padding="12dp"/>
</FrameLayout>