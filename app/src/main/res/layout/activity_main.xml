<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Restaurant POS"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <Button
        android:id="@+id/btnTakePayment"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="TAKE PAYMENT"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnTransactions"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="TRANSACTIONS"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnSettle"
        android:layout_width="220dp"
        android:layout_height="wrap_content"
        android:text="SETTLE BATCH"/>

    <TextView
        android:id="@+id/txtTodayTotal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today: $0.00"
        android:textSize="16sp"
        android:layout_marginTop="40dp"/>

    <TextView
        android:id="@+id/txtTodayCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Transactions: 0"
        android:textSize="16sp"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnEmployees"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="EMPLOYEES"
        android:layout_marginTop="16dp"
        android:backgroundTint="#6A4FB3"
        android:textColor="@android:color/white"/>

</LinearLayout>
