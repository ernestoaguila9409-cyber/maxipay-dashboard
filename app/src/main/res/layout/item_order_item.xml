<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="18dp"
    app:cardElevation="8dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E0E0E0"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <!-- Item name + qty -->
        <TextView
            android:id="@+id/txtItemNameQty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp" />

        <!-- Base price (we will hide if 0) -->
        <TextView
            android:id="@+id/txtItemBase"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:layout_marginTop="4dp" />

        <!-- Modifiers (we can hide if empty) -->
        <TextView
            android:id="@+id/txtItemModifiers"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:layout_marginTop="10dp" />

        <!-- Line total (at bottom, not beside name) -->
        <TextView
            android:id="@+id/txtItemLineTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />

        <TextView
            android:id="@+id/txtItemPayments"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#555555"
            android:layout_marginTop="4dp"
            android:visibility="gone"/>

        <!-- Refunded by + date (right-aligned, shown only for refunded items) -->
        <LinearLayout
            android:id="@+id/refundedByRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end"
            android:layout_marginTop="6dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/txtRefundedBy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#1565C0"
                android:textStyle="italic"/>
            <TextView
                android:id="@+id/txtRefundedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#1565C0"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>