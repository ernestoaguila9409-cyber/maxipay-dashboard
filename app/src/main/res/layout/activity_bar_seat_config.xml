<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Seats Configuration"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="24dp"
        android:paddingBottom="4dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Manage bar seats that appear in the Bar Tab screen."
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="16dp"/>

    <TextView
        android:id="@+id/txtEmptyState"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No bar seats configured yet.\nTap + to add one."
        android:textSize="15sp"
        android:textColor="#999999"
        android:gravity="center"
        android:padding="48dp"
        android:visibility="gone"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerSeats"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:clipToPadding="false"/>

    <Button
        android:id="@+id/btnAddSeat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="+ Add Seat"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#6A4FB3"
        android:textColor="@android:color/white"/>

</LinearLayout>
