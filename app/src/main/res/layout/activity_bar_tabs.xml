<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F5F5F5">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#6A4FB3"
            android:title="Bar Tabs"
            android:titleTextColor="@android:color/white"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerBarTabs"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"
            android:clipToPadding="false"/>

        <Button
            android:id="@+id/btnNewTab"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="+ New Tab"
            android:textSize="16sp"
            android:textStyle="bold"
            android:backgroundTint="#6A4FB3"
            android:textColor="@android:color/white"/>

    </LinearLayout>

    <!-- Loading overlay shown during PreAuth -->
    <LinearLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="@android:color/white"/>

        <TextView
            android:id="@+id/txtLoadingMessage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Opening tab…"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

    </LinearLayout>

</FrameLayout>
