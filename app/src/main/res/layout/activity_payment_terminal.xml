<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    android:padding="24dp">

    <TextView
        android:id="@+id/txtScreenTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add Terminal"
        android:textSize="20sp"
        android:textStyle="bold"
        android:paddingBottom="8dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configure your terminal credentials."
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:paddingBottom="24dp"/>

    <!-- Terminal Name -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Terminal Name"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:paddingBottom="4dp"/>

    <EditText
        android:id="@+id/edtTerminalName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. Front Counter"
        android:inputType="text"
        android:background="@android:color/white"
        android:padding="14dp"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <!-- TPN -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TPN"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:paddingBottom="4dp"/>

    <EditText
        android:id="@+id/edtTpn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter TPN"
        android:inputType="text"
        android:background="@android:color/white"
        android:padding="14dp"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <!-- IP Address (for health check) -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="IP Address"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:paddingBottom="4dp"/>

    <EditText
        android:id="@+id/edtIpAddress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="e.g. 192.168.1.100"
        android:inputType="text"
        android:background="@android:color/white"
        android:padding="14dp"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <!-- Register ID -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Register ID"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:paddingBottom="4dp"/>

    <EditText
        android:id="@+id/edtRegisterId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Register ID"
        android:inputType="text"
        android:background="@android:color/white"
        android:padding="14dp"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <!-- Auth Key -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Auth Key"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:paddingBottom="4dp"/>

    <EditText
        android:id="@+id/edtAuthKey"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Auth Key"
        android:inputType="text"
        android:background="@android:color/white"
        android:padding="14dp"
        android:textSize="16sp"
        android:layout_marginBottom="24dp"/>

    <!-- Save Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSaveTerminal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save"/>

    <!-- Delete Button (edit mode only) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDeleteTerminal"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Delete Terminal"
        android:textColor="#D32F2F"
        android:visibility="gone"
        android:layout_marginTop="8dp"/>

</LinearLayout>
