<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="@color/pos_key_ripple">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:radius="@dimen/pos_key_corner_radius" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/pos_key_enter_fill" />
            <stroke
                android:width="1dp"
                android:color="@color/pos_key_enter_stroke" />
            <corners android:radius="@dimen/pos_key_corner_radius" />
        </shape>
    </item>
</ripple>
