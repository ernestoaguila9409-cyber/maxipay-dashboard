NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only: menu picture scan (POST /api/menu/scan).
# Production (Vercel, etc.): set FIREBASE_SERVICE_ACCOUNT_JSON to the ENTIRE contents of the Firebase service account JSON (one line is OK).
# Local: optional; otherwise use serviceAccountKey.json next to package.json (from Firebase Console → Generate new private key).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional: override default bucket if different from NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET
# FIREBASE_STORAGE_BUCKET=
OPENAI_API_KEY=
# Optional: default gpt-4o-mini
# OPENAI_MENU_MODEL=gpt-4o-mini

# iPOSpays Hosted Payment Page — online card payments (LIVE merchant)
# IPOS_HPP_TPN and IPOS_HPP_AUTH_TOKEN must be issued by iPOSpays for the SAME
# environment as IPOS_HPP_BASE_URL below. Mixing live token + sandbox URL (or
# vice-versa) returns a "Link Expired" page on redirect.
IPOS_HPP_TPN=
IPOS_HPP_AUTH_TOKEN=
# Optional: if iPOSpays gives a separate key for GET queryPaymentStatus, set it here (else AUTH_TOKEN is used).
# IPOS_HPP_QUERY_API_KEY=
# Optional: defaults to PRODUCTION (https://payment.ipospays.com/api/v1/external-payment-transaction).
# Only set this to the sandbox URL when testing with sandbox credentials:
# IPOS_HPP_BASE_URL=https://payment.ipospays.tech/api/v1/external-payment-transaction
